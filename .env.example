# ---------------------------------------------------------------
# Base de datos — Postgres (Neon gestionado desde Vercel)
# Ver docs/setup-db-vercel.md para obtener estos valores.
# ---------------------------------------------------------------

# Conexión POOLED (con -pooler en el host): la usa la API en runtime.
DATABASE_URL="postgres://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/DBNAME?sslmode=require"

# Conexión DIRECTA (sin -pooler): la usa el runner de migraciones (DDL).
# Si no la definís, las migraciones caen a DATABASE_URL.
DATABASE_URL_UNPOOLED="postgres://USER:PASSWORD@ep-xxx.region.aws.neon.tech/DBNAME?sslmode=require"

# ---------------------------------------------------------------
# API
# ---------------------------------------------------------------
PORT=3001

# ---------------------------------------------------------------
# Web (Vite) -> dónde corre la API
# ---------------------------------------------------------------
VITE_API_URL="http://localhost:3001"
